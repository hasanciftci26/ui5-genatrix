		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@ui5/cli": "^4.0.50",
		"eslint": "9.39.1",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.2",
		"ui5-tooling-transpile": "^3.11.0"
	}
}
