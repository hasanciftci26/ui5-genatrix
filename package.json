{
	"name": "ui5-genatrix",
	"version": "0.0.1",
	"description": "UI5 Genatrix",
	"author": "Hasan Çiftçi (hasanciftcii26@gmail.com)",
	"license": "UNLICENSED",
	"keywords": [
		"sapui5",
		"odata",
		"metadata",
		"generic-ui"
	],
	"repository": {
		"url": "https://github.com/hasanciftci26/ui5-genatrix"
	},
	"files": [
		"dist",
		"ui5.yaml",
		"LICENSE",
		"README.md"
	],
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "ui5 build --config=ui5-npm.yaml --clean-dest",
		"prepack": "npm run build && rimraf --glob dist/**/*.d.ts.map",
		"local-install": "npm pack && npm --prefix test/v2 run install-tgz"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "9.39.1",
		"@sap-ux/eslint-plugin-fiori-tools": "^9.11.3",
