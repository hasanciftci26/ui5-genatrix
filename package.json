{
	"name": "ui5-genatrix",
	"version": "0.0.1",
	"description": "UI5 Genatrix",
	"author": "Hasan Çiftçi (hasanciftcii26@gmail.com)",
	"license": "UNLICENSED",
	"keywords": [
		"sapui5",
		"odata",
		"metadata",
		"generic-ui"
	],
	"repository": {
		"url": "https://github.com/hasanciftci26/ui5-genatrix"
	},
	"files": [
		"dist",
		"ui5.yaml",
		"LICENSE",
		"README.md"
	],
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "ui5 build --config=ui5-npm.yaml --clean-dest",
		"prepack": "npm run build && rimraf --glob dist/**/*.d.ts.map",
		"local-install-v2": "npm pack && npm --prefix test/v2 run install-tgz"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@sap-ux/eslint-plugin-fiori-tools": "10.1.1",
		"@sapui5/types": "1.136.18",
		"@typescript-eslint/eslint-plugin": "8.59.3",
		"@typescript-eslint/parser": "8.59.3",
		"@ui5/cli": "4.0.53",
		"eslint": "10.4.0",
		"rimraf": "6.1.3",
		"typescript": "5.9.3",
		"ui5-tooling-transpile": "3.11.0"
	}
}
