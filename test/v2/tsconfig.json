{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "strict": true,
        "noImplicitOverride": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "skipLibCheck": true,
        "noEmitOnError": true,
        "useUnknownInCatchVariables": true,
        "noImplicitThis": true,
        "noImplicitAny": false,
        "allowJs": false,
        "sourceMap": false,
        "inlineSourceMap": false,
        "strictPropertyInitialization": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": "./",
        "rootDir": "./webapp",
        "outDir": "./dist",
        "paths": {
            "ui5/genatrix/test/v2/*": [
                "./webapp/*"
            ]
        },
        "types": [
            "@sapui5/types"
        ]
    },
    "include": [
        "webapp"
    ]
}